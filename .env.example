# CupOracle configuration — copy to .env.local and fill in.
# The 4 free data tools need the two API keys. wc_edge needs a funded payer key.

# --- Data APIs ---
# football-data.org free tier (competition 2000 = FIFA World Cup)
FOOTBALL_DATA_KEY=
# the-odds-api.com (500 req/mo free tier)
ODDS_API_KEY=

# --- x402 payer wallet (fund with a few CENTS of USDC only) ---
# Hex private key of the agent's throwaway payment wallet. Used to sign EIP-3009
# transfer authorizations for wc_edge. NEVER use your main seed.
CUPORACLE_PRIVATE_KEY=

# --- Spend governance ---
# Per-session spend cap in USDC (default 0.50). wc_edge refuses to exceed it.
CUPORACLE_MAX_SPEND=0.50

# --- Network ---
# eip155:1776 = Injective EVM mainnet, eip155:1439 = testnet
CUPORACLE_NETWORK=eip155:1776

# --- Upstream edge provider (sibling LineLock app) ---
# wc_edge POSTs here and pays the returned x402 402 quote. Degrades gracefully
# to free odds if unreachable.
LINELOCK_URL=https://linelock.edycu.dev

# --- Optional: receipt store + keystore locations ---
# CUPORACLE_HOME=~/.cuporacle
